{
  "version": 2,
  "builds": [
    { "src": "client/next.config.js", "use": "@vercel/next" },
    {
      "src": "server/api/index.ts",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 60,
        "excludeFiles": "client/**"
      }
    }
  ],
  "rewrites": [
    { "source": "/auth/(.*)", "destination": "/server/api/index.ts" },
    { "source": "/contracts/(.*)", "destination": "/server/api/index.ts" },
    { "source": "/payments/(.*)", "destination": "/server/api/index.ts" },
    { "source": "/healthz", "destination": "/server/api/index.ts" }
  ]
}
