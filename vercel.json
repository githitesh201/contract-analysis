{
  "version": 2,
  "builds": [
    { "src": "client/next.config.js", "use": "@vercel/next" },
    {
      "src": "server/api/index.ts",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 60,
        "excludeFiles": "client/**"
      }
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/auth/(.*)", "dest": "/server/api/index.ts" },
    { "src": "/contracts/(.*)", "dest": "/server/api/index.ts" },
    { "src": "/payments/(.*)", "dest": "/server/api/index.ts" },
    { "src": "/healthz", "dest": "/server/api/index.ts" },
    { "src": "/", "dest": "/client" },
    { "src": "/(.*)", "dest": "/client/$1" }
  ]
}
